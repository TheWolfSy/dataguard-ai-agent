rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    //   - role: string (Administrator, Data Analyst, Read-Only User)
    //
    // Collection: data_logs
    //   - uid: string (Owner)
    //   - content: string (Encrypted)
    //
    // Collection: audit_logs
    //   - uid: string (Actor)
    //   - operation: string
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Administrator') || (request.auth.token.email == "shadialjasem685@gmail.com" && request.auth.token.email_verified == true);
    }

    function isAnalyst() {
      return hasRole('Data Analyst');
    }

    function isReadOnly() {
      return hasRole('Read-Only User');
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // RBAC Enforcement
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin(); // Only admins can change roles
    }

    match /data_logs/{logId} {
      // Read-Only User can only see their own logs
      // Analyst can see all logs
      // Admin can see all logs
      allow read: if isOwner(resource.data.uid) || isAdmin() || isAnalyst();
      
      // Only Admin and Analyst can create/update logs
      allow create: if (isAdmin() || isAnalyst()) && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /security_policies/{policyId} {
      allow read: if isOwner(resource.data.uid) || isAdmin() || isAnalyst();
      allow create: if isAdmin() || isAnalyst();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audit_logs/{auditId} {
      // Only Admins can see audit logs
      allow read: if isAdmin();
      // System (authenticated users) can create logs
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // Audit logs are immutable
    }
  }
}
