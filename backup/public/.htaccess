# ===================================================
# DataGuard AI — Apache Configuration for InfinityFree
# ===================================================

Options -Indexes

# -------------------------------------------------------
# MIME Types — ضروري لتشغيل PGlite WebAssembly
# -------------------------------------------------------
AddType application/wasm                    .wasm
AddType application/octet-stream            .data
AddType application/javascript              .js .mjs
AddType text/css                            .css
AddType image/png                           .png
AddType image/svg+xml                       .svg
AddType image/x-icon                        .ico

# -------------------------------------------------------
# Cross-Origin Headers — مطلوبة لـ WebAssembly / SharedArrayBuffer
# -------------------------------------------------------
<IfModule mod_headers.c>
    # للملفات الثابتة (assets) — cache طويل
    <FilesMatch "\.(js|mjs|css|woff2|woff|ttf|eot|png|svg|ico|jpg|jpeg|webp|gif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # للـ WASM و data files — headers خاصة بـ COOP/COEP
    <FilesMatch "\.(wasm|data)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header set Cross-Origin-Opener-Policy "same-origin"
        Header set Cross-Origin-Embedder-Policy "require-corp"
        Header set Cross-Origin-Resource-Policy "same-origin"
    </FilesMatch>

    # للـ service worker — لا cache
    <FilesMatch "^sw\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Service-Worker-Allowed "/"
    </FilesMatch>

    # لصفحة HTML — لا cache
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set X-Content-Type-Options "nosniff"
        Header set X-Frame-Options "SAMEORIGIN"
        Header set Referrer-Policy "strict-origin-when-cross-origin"
        Header set Cross-Origin-Opener-Policy "same-origin"
        Header set Cross-Origin-Embedder-Policy "require-corp"
    </FilesMatch>

    # أمان عام على كل الصفحات
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# -------------------------------------------------------
# Gzip Compression — تسريع التحميل
# -------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    # لا تضغط الـ WASM لأنه مضغوط مسبقاً
    SetEnvIfNoCase Request_URI \.wasm$ no-gzip dont-vary
</IfModule>

# -------------------------------------------------------
# SPA Routing — إعادة توجيه كل المسارات لـ index.html
# -------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # لا تُعيد توجيه الملفات والمجلدات الموجودة فعلاً
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # أعد توجيه كل شيء آخر لـ index.html
    RewriteRule ^ index.html [QSA,L]
</IfModule>
